    "stepLabel": {
      "type": "string",
      "default": "Step"
    }
  },
  "supports": {
    "html": false,
    "reusable": false,
    "anchor": false
  },
  "editorScript": "icts-how-it-works-step-editor",
  "editorStyle": "icts-how-it-works-step-editor",
  "style": "icts-how-it-works-step-style"
}
